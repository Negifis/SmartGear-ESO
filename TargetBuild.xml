<GuiXml>
    <Controls>
        <TopLevelControl name="SmartGearBuildBrowser" hidden="true" movable="true"
                         clampedToScreen="true" mouseEnabled="true"
                         layer="OVERLAY" level="50">
            <Dimensions x="720" y="560" />
            <Anchor point="CENTER" relativeTo="GuiRoot" relativePoint="CENTER" />

            <Controls>
                <!-- BG created in Lua -->

                <!-- Header -->
                <Control name="$(parent)Header">
                    <Dimensions x="720" y="32" />
                    <Anchor point="TOPLEFT" />
                    <Controls>
                        <Label name="$(parent)Title" font="ZoFontWinH4" color="00FF00"
                               horizontalAlignment="CENTER" verticalAlignment="CENTER"
                               text="SmartGear -- Target Build">
                            <AnchorFill />
                        </Label>
                    </Controls>
                </Control>

                <!-- Close button -->
                <Button name="$(parent)CloseBtn" mouseEnabled="true">
                    <Dimensions x="28" y="28" />
                    <Anchor point="TOPRIGHT" offsetX="-4" offsetY="2" />
                    <Controls>
                        <Label name="$(parent)Label" font="ZoFontGameBold" color="FF4444"
                               horizontalAlignment="CENTER" verticalAlignment="CENTER"
                               text="X">
                            <AnchorFill />
                        </Label>
                    </Controls>
                </Button>

                <!-- LEFT PANEL -->
                <Control name="$(parent)LeftPanel">
                    <Dimensions x="260" y="510" />
                    <Anchor point="TOPLEFT" offsetX="8" offsetY="38" />
                    <Controls>
                        <!-- Search input -->
                        <EditBox name="$(parent)SearchBox" mouseEnabled="true"
                                 font="ZoFontGame" maxInputChars="40"
                                 multiLine="false" newLineEnabled="false"
                                 editEnabled="true" selectAllOnFocus="true">
                            <Dimensions x="254" y="22" />
                            <Anchor point="TOPLEFT" offsetX="2" offsetY="1" />
                        </EditBox>

                        <!-- Filter buttons row -->
                        <Control name="$(parent)Filters">
                            <Dimensions x="258" y="22" />
                            <Anchor point="TOPLEFT" offsetX="0" offsetY="28" />
                        </Control>

                        <!-- Build list container -->
                        <Control name="$(parent)List" mouseEnabled="true">
                            <Dimensions x="258" y="450" />
                            <Anchor point="TOPLEFT" offsetX="0" offsetY="54" />
                        </Control>
                    </Controls>
                </Control>

                <!-- RIGHT PANEL -->
                <Control name="$(parent)RightPanel" hidden="true">
                    <Dimensions x="430" y="510" />
                    <Anchor point="TOPRIGHT" offsetX="-8" offsetY="38" />
                    <Controls>
                        <Label name="$(parent)BuildName" font="ZoFontWinH3" color="FFFFFF"
                               horizontalAlignment="LEFT" verticalAlignment="TOP"
                               wrapMode="ELLIPSIS" text="">
                            <Dimensions x="410" y="26" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="8" />
                        </Label>

                        <Label name="$(parent)RoleCtx" font="ZoFontGame" color="AAAAAA"
                               horizontalAlignment="LEFT" text="">
                            <Dimensions x="410" y="18" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="36" />
                        </Label>

                        <Label name="$(parent)Progress" font="ZoFontGameBold" color="00FF00"
                               horizontalAlignment="LEFT" text="">
                            <Dimensions x="410" y="20" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="58" />
                        </Label>

                        <Control name="$(parent)SetList">
                            <Dimensions x="410" y="350" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="84" />
                        </Control>

                        <!-- Activate button -->
                        <Button name="$(parent)ActivateBtn" mouseEnabled="true">
                            <Dimensions x="150" y="32" />
                            <Anchor point="BOTTOMLEFT" offsetX="10" offsetY="-8" />
                            <Controls>
                                <Label name="$(parent)Label" font="ZoFontGameBold" color="FFFFFF"
                                       horizontalAlignment="CENTER" verticalAlignment="CENTER"
                                       text="ACTIVATE">
                                    <AnchorFill />
                                </Label>
                            </Controls>
                        </Button>

                        <!-- Deactivate button -->
                        <Button name="$(parent)DeactivateBtn" mouseEnabled="true" hidden="true">
                            <Dimensions x="150" y="32" />
                            <Anchor point="BOTTOMLEFT" offsetX="170" offsetY="-8" />
                            <Controls>
                                <Label name="$(parent)Label" font="ZoFontGameBold" color="FFFFFF"
                                       horizontalAlignment="CENTER" verticalAlignment="CENTER"
                                       text="DEACTIVATE">
                                    <AnchorFill />
                                </Label>
                            </Controls>
                        </Button>
                    </Controls>
                </Control>

                <!-- No build selected -->
                <Label name="$(parent)NoBuildLabel" font="ZoFontGame" color="555555"
                       horizontalAlignment="CENTER" verticalAlignment="CENTER" text="">
                    <Dimensions x="430" y="510" />
                    <Anchor point="TOPRIGHT" offsetX="-8" offsetY="38" />
                </Label>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>
