<GuiXml>
    <Controls>
        <!-- Build Browser main window -->
        <TopLevelControl name="SmartGearBuildBrowser" hidden="true" movable="true"
                         clampedToScreen="true" mouseEnabled="true"
                         layer="OVERLAY" level="50">
            <Dimensions x="680" y="520" />
            <Anchor point="CENTER" relativeTo="GuiRoot" relativePoint="CENTER" />

            <Controls>
                <!-- Background -->
                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop">
                    <AnchorFill />
                    <Edge edgeSize="2" />
                </Backdrop>

                <!-- Header bar -->
                <Control name="$(parent)Header">
                    <Dimensions x="680" y="32" />
                    <Anchor point="TOPLEFT" />
                    <Controls>
                        <Backdrop name="$(parent)BG">
                            <AnchorFill />
                            <Center r="0" g="0.15" b="0" a="0.9" />
                        </Backdrop>
                        <Label name="$(parent)Title" font="ZoFontWinH4" color="00FF00"
                               horizontalAlignment="CENTER" verticalAlignment="CENTER"
                               text="SmartGear -- Target Build">
                            <AnchorFill />
                        </Label>
                    </Controls>
                </Control>

                <!-- Close button -->
                <Button name="$(parent)CloseBtn" mouseEnabled="true">
                    <Dimensions x="28" y="28" />
                    <Anchor point="TOPRIGHT" offsetX="-4" offsetY="2" />
                    <Controls>
                        <Label name="$(parent)Label" font="ZoFontGameBold" color="FF4444"
                               horizontalAlignment="CENTER" verticalAlignment="CENTER"
                               text="X">
                            <AnchorFill />
                        </Label>
                    </Controls>
                </Button>

                <!-- LEFT PANEL: Build list container -->
                <Control name="$(parent)LeftPanel">
                    <Dimensions x="220" y="470" />
                    <Anchor point="TOPLEFT" offsetX="8" offsetY="40" />
                    <Controls>
                        <Label name="$(parent)FilterLabel" font="ZoFontGameBold" color="AAAAAA"
                               text="Builds:" horizontalAlignment="LEFT">
                            <Dimensions x="220" y="20" />
                            <Anchor point="TOPLEFT" />
                        </Label>
                        <!-- Rows created dynamically in Lua -->
                        <Control name="$(parent)List">
                            <Dimensions x="220" y="440" />
                            <Anchor point="TOPLEFT" offsetY="24" />
                        </Control>
                    </Controls>
                </Control>

                <!-- RIGHT PANEL: Build details -->
                <Control name="$(parent)RightPanel">
                    <Dimensions x="430" y="470" />
                    <Anchor point="TOPRIGHT" offsetX="-8" offsetY="40" />

                    <Controls>
                        <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop">
                            <AnchorFill />
                            <Center r="0.05" g="0.05" b="0.05" a="0.6" />
                        </Backdrop>

                        <Label name="$(parent)BuildName" font="ZoFontWinH3" color="FFFFFF"
                               horizontalAlignment="LEFT" verticalAlignment="TOP"
                               wrapMode="ELLIPSIS" text="">
                            <Dimensions x="410" y="26" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="8" />
                        </Label>

                        <Label name="$(parent)RoleCtx" font="ZoFontGame" color="AAAAAA"
                               horizontalAlignment="LEFT" text="">
                            <Dimensions x="410" y="18" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="36" />
                        </Label>

                        <Label name="$(parent)Progress" font="ZoFontGameBold" color="00FF00"
                               horizontalAlignment="LEFT" text="">
                            <Dimensions x="410" y="20" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="58" />
                        </Label>

                        <!-- Set details container (rows created in Lua) -->
                        <Control name="$(parent)SetList">
                            <Dimensions x="410" y="320" />
                            <Anchor point="TOPLEFT" offsetX="10" offsetY="84" />
                        </Control>

                        <!-- Activate button -->
                        <Button name="$(parent)ActivateBtn" mouseEnabled="true">
                            <Dimensions x="140" y="32" />
                            <Anchor point="BOTTOMLEFT" offsetX="10" offsetY="-8" />
                            <Controls>
                                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop">
                                    <AnchorFill />
                                    <Center r="0" g="0.4" b="0" a="0.9" />
                                </Backdrop>
                                <Label name="$(parent)Label" font="ZoFontGameBold" color="FFFFFF"
                                       horizontalAlignment="CENTER" verticalAlignment="CENTER"
                                       text="ACTIVATE">
                                    <AnchorFill />
                                </Label>
                            </Controls>
                        </Button>

                        <!-- Deactivate button -->
                        <Button name="$(parent)DeactivateBtn" mouseEnabled="true" hidden="true">
                            <Dimensions x="140" y="32" />
                            <Anchor point="BOTTOMLEFT" offsetX="160" offsetY="-8" />
                            <Controls>
                                <Backdrop name="$(parent)BG" inherits="ZO_DefaultBackdrop">
                                    <AnchorFill />
                                    <Center r="0.4" g="0.15" b="0" a="0.9" />
                                </Backdrop>
                                <Label name="$(parent)Label" font="ZoFontGameBold" color="FFFFFF"
                                       horizontalAlignment="CENTER" verticalAlignment="CENTER"
                                       text="DEACTIVATE">
                                    <AnchorFill />
                                </Label>
                            </Controls>
                        </Button>
                    </Controls>
                </Control>

                <!-- Placeholder when no build selected -->
                <Label name="$(parent)NoBuildLabel" font="ZoFontGame" color="666666"
                       horizontalAlignment="CENTER" verticalAlignment="CENTER"
                       text="Select a build from the list" hidden="true">
                    <Dimensions x="430" y="470" />
                    <Anchor point="TOPRIGHT" offsetX="-8" offsetY="40" />
                </Label>
            </Controls>
        </TopLevelControl>
    </Controls>
</GuiXml>
